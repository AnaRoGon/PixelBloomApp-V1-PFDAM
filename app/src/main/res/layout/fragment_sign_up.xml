<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/sign_up_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutral_50"
    android:orientation="vertical"
    tools:context=".view.fragment.auth.SignUpFragment">

    <!-- ScrollView para que el usuario pueda hacer scroll hay abajo y no pierda la información, independientemente del formato del móvil-->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/sign_up_toolbar">


        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="32dp">

            <!--Imagen del fondo con background con gradiente para el login -->
            <ImageView
                android:id="@+id/sign_up_background"
                android:layout_width="wrap_content"
                android:layout_height="550dp"
                android:layout_gravity="top"
                android:contentDescription="@string/background_image"
                android:padding="16dp"
                android:scaleType="fitXY"
                android:src="@drawable/login_signup_background"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/login_overlay"
                android:layout_width="wrap_content"
                android:layout_height="550dp"
                android:layout_gravity="top"
                android:contentDescription="@string/background_overlay"
                android:padding="16dp"
                android:scaleType="fitXY"
                android:src="@drawable/overlay"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!--Cardview que contiene el logotipo-->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:elevation="0dp"
                app:cardBackgroundColor="@color/neutral_50"
                app:cardCornerRadius="60dp"
                app:layout_constraintBottom_toTopOf="@+id/sign_up_title"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:strokeWidth="0dp">

                <ImageView
                    android:id="@+id/sign_up_logo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/logotipe_app"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_logo"
                    app:layout_constraintBottom_toTopOf="@+id/sign_up_title"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />
            </com.google.android.material.card.MaterialCardView>
            <!--Tïtulo de bienvenida de la app-->
            <TextView
                android:id="@+id/sign_up_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:fontFamily="@font/inconsolata_black"
                android:scaleType="fitCenter"
                android:text="@string/welcome_to_pixel_bloom"
                android:textSize="27sp"
                app:layout_constraintBottom_toBottomOf="@+id/sign_up_background"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <!--Caja del textInput para el mail-->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/outlined_text_field_email"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:hint="@string/email"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/sign_up_background"
                app:startIconDrawable="@drawable/material_symbols_mail_outline">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:paddingStart="50dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!--Caja del textInput para contraseña -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/outlined_text_field_password"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:hint="@string/password"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/outlined_text_field_email"
                app:startIconDrawable="@drawable/mdi_password">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:paddingStart="50dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!--Caja del textInput para confirmar contraseña -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/outlined_text_field_confirm_password"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:hint="@string/confirm_password"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/outlined_text_field_password"
                app:startIconDrawable="@drawable/mdi_password">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:paddingStart="50dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!--Botón para registrarse -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/sign_up_button"
                style="@style/PixelBloomButton"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:soundEffectsEnabled="true"
                android:text="@string/sign_up"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/outlined_text_field_confirm_password" />

            <!-- Layout para organizar texto informativo y el botón de login -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/sign_up_button">
                <!-- Texto informativo para el usuario-->
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/text_view_sign_up"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:text="@string/already_have_account" />
                <!-- TextButton para registrars en la app -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/text_button_login"
                    style="@style/PixelBloomTextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:soundEffectsEnabled="true"
                    android:text="@string/sign_in_here" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>


    <!-- Toolbar personalizada para ir atrás y ayudar a la navegación intuitiva del usuario -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/sign_up_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        android:elevation="5dp"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_back_arrow" />

</androidx.constraintlayout.widget.ConstraintLayout>
