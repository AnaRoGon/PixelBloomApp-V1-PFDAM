<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutral_200"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:focusableInTouchMode="true"
    android:paddingTop="50dp"
    android:paddingBottom="80dp">


    <!--Contenedor de los principales elementos -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/neutral_200"
        android:padding="16dp">

        <!--  Título del layout para aceptar un nuevo challenge -->
        <TextView
            android:id="@+id/title_text_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:fontFamily="@font/inconsolata_black"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="@string/your_today_s_chal"
            android:textSize="20sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Cardview para que s emuestre la imagen que se quiere subir -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/challenge_card_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="25dp"
            android:elevation="6dp"
            app:cardBackgroundColor="@color/neutral_50"
            app:cardCornerRadius="20dp"
            app:layout_constraintEnd_toEndOf="@+id/title_text_view"
            app:layout_constraintStart_toStartOf="@+id/title_text_view"
            app:layout_constraintTop_toBottomOf="@+id/title_text_view"
            app:strokeColor="@color/black"
            app:strokeWidth="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:layout_margin="16dp"
                    android:gravity="center"
                    android:paddingTop="15dp"
                    android:text="@string/your_palette"
                    android:textSize="16sp" />

                <!-- Contenedor de la paleta -->
                <LinearLayout
                    android:id="@+id/palette_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/hex_01"
                        android:layout_width="0dp"
                        android:layout_height="60dp"
                        android:layout_weight="1"
                        android:background="@color/dirty_orange"
                        android:contentDescription="@string/first_color" />

                    <ImageView
                        android:id="@+id/hex_02"
                        android:layout_width="0dp"
                        android:layout_height="60dp"
                        android:layout_weight="1"
                        android:background="@color/orange"
                        android:contentDescription="@string/second_color" />

                    <ImageView
                        android:id="@+id/hex_03"
                        android:layout_width="0dp"
                        android:layout_height="60dp"
                        android:layout_weight="1"
                        android:background="@color/inactive_blue"
                        android:contentDescription="@string/third_color" />

                    <ImageView
                        android:id="@+id/hex_04"
                        android:layout_width="0dp"
                        android:layout_height="60dp"
                        android:layout_weight="1"
                        android:background="@color/light_purple"
                        android:contentDescription="@string/fourth_color" />

                    <ImageView
                        android:id="@+id/hex_05"
                        android:layout_width="0dp"
                        android:layout_height="60dp"
                        android:layout_weight="1"
                        android:background="@color/purple"
                        android:contentDescription="@string/fifth_color" />
                </LinearLayout>

                <!--Titulo de presentación para la frase inspiradora-->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:layout_margin="16dp"
                    android:gravity="center"
                    android:text="@string/your_inspiration"
                    android:textSize="16sp" />

                <!-- Elemento decorativo dar marco a la frase inspiradora-->
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="5dp"
                    android:background="@color/black"
                    android:backgroundTint="@color/black"
                    android:contentDescription="@string/separation_line" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:background="@color/banana_light"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/challenge_description_text"
                        android:layout_width="350dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:fontFamily="@font/inconsolata_black"
                        android:gravity="center"
                        android:paddingStart="50dp"
                        android:paddingTop="50dp"
                        android:paddingEnd="50dp"
                        android:paddingBottom="50dp"
                        android:text="@string/eat_rainbow_treats_and_purr_like_a_happy_cat"
                        android:textColor="@color/neutral_900"
                        android:textSize="25sp" />

                </LinearLayout>
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!--  Contenedor de los botones para aceptar o cancelar -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:divider="@drawable/spacer_50dp"
            android:orientation="horizontal"
            android:paddingTop="20dp"
            android:paddingBottom="30dp"
            app:layout_constraintEnd_toEndOf="@+id/challenge_card_view"
            app:layout_constraintStart_toStartOf="@+id/challenge_card_view"
            app:layout_constraintTop_toBottomOf="@+id/challenge_card_view">

            <!--Botón de cancelar -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/cancel_button"
                style="@style/PixelBloomButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="20dp"
                android:layout_weight="1"
                android:backgroundTint="@color/btn_cancel_color"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:soundEffectsEnabled="true"
                app:icon="@drawable/ic_decline"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="19dp" />

            <!--Botón de confirmar -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/ok_button"
                style="@style/PixelBloomButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_weight="1"
                android:backgroundTint="@color/purple"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:soundEffectsEnabled="true"
                app:icon="@drawable/ic_confirm"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="22dp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>