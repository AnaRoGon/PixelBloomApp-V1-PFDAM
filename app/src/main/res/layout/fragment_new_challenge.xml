<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:focusableInTouchMode="true"
    android:paddingTop="16dp">


    <!-- ScrollView para poder desplazar la información si es muy larga -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">


        <LinearLayout
            android:id="@+id/search_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Barra de arrastre -->
            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp"
                android:background="@color/neutral_300" />


            <!-- Contenedor para el título y, en su caso, el botón de eliminar -->
            <LinearLayout
                android:id="@+id/title_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:elevation="10dp"
                android:gravity="center"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">


                <!--  Título del formulario -->
                <TextView
                    android:id="@+id/title_text_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="15dp"
                    android:fontFamily="@font/inconsolata_black"
                    android:gravity="center"
                    android:text="@string/add_new_challenge"
                    android:textSize="20dp" />

                <ImageButton
                    android:id="@+id/delete_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/transparent"
                    android:contentDescription="@string/cd_delete_challenge"
                    android:paddingStart="35dp"
                    android:src="@drawable/ic_delete"
                    android:visibility="gone" />
            </LinearLayout>


            <!--CardView de paleta de colores que se actualizará con la paleta generada -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/challenge_palette_container"
                android:layout_width="350dp"
                android:layout_height="wrap_content"
                app:cardCornerRadius="0dp"
                app:cardElevation="10dp"
                app:cardUseCompatPadding="true"
                app:layout_constraintEnd_toEndOf="@+id/challenge_options_container"
                app:layout_constraintStart_toStartOf="@+id/challenge_options_container"
                app:layout_constraintTop_toBottomOf="parent"
                app:strokeColor="@color/black"
                app:strokeWidth="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:background="@color/neutral_50"
                    android:orientation="vertical"
                    android:padding="5dp">

                    <!-- Indicador de carga -->
                    <ProgressBar
                        android:id="@+id/loading_progress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp"
                        android:visibility="gone" />
                    <!--Contenedor de la paleta del reto-->
                    <LinearLayout
                        android:id="@+id/palette_container"
                        android:layout_width="250dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_margin="10dp"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/hex_01"
                            android:layout_width="0dp"
                            android:layout_height="60dp"
                            android:layout_weight="1"
                            android:background="@color/dirty_orange"
                            android:contentDescription="@string/first_color" />

                        <ImageView
                            android:id="@+id/hex_02"
                            android:layout_width="0dp"
                            android:layout_height="60dp"
                            android:layout_weight="1"
                            android:background="@color/orange"
                            android:contentDescription="@string/second_color" />

                        <ImageView
                            android:id="@+id/hex_03"
                            android:layout_width="0dp"
                            android:layout_height="60dp"
                            android:layout_weight="1"
                            android:background="@color/inactive_blue"
                            android:contentDescription="@string/third_color" />

                        <ImageView
                            android:id="@+id/hex_04"
                            android:layout_width="0dp"
                            android:layout_height="60dp"
                            android:layout_weight="1"
                            android:background="@color/light_purple"
                            android:contentDescription="@string/fourth_color" />

                        <ImageView
                            android:id="@+id/hex_05"
                            android:layout_width="0dp"
                            android:layout_height="60dp"
                            android:layout_weight="1"
                            android:background="@color/purple"
                            android:contentDescription="@string/fifth_color" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>


            <!-- Instrucciones para generar paleta de color aleatoria en base a un hex-->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="15dp"
                android:fontFamily="@font/inconsolata_black"
                android:gravity="center"
                android:padding="10dp"
                android:text="@string/enter_keyword_palette" />

            <!--Caja de textInput para la búsqueda-->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/outlined_text_input_search"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:hint="@string/key_word"
                android:paddingBottom="25dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:paddingStart="16dp" />
            </com.google.android.material.textfield.TextInputLayout>


            <!--Botón para seleccionar iniciar búsqueda -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/search_palette"
                style="@style/PixelBloomButton"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/btn_purple_pixel_bloom_color"
                android:text="@string/generate_palette" />


            <!--Titulo explicativo para la descripción del reto-->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="15dp"
                android:fontFamily="@font/inconsolata_black"
                android:gravity="center"
                android:padding="10dp"
                android:text="@string/write_inspiring_description" />

            <!--Caja del TextInput para description-->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/outlined_text_area_description"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:hint="@string/description"
                android:paddingTop="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:lines="6"
                    android:overScrollMode="always"
                    android:paddingStart="16dp"
                    android:scrollbarStyle="insideInset"
                    android:scrollbars="vertical"
                    android:scrollHorizontally="false" />
            </com.google.android.material.textfield.TextInputLayout>

            <!--Titulo explicativo para la descripción del reto-->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="15dp"
                android:fontFamily="@font/inconsolata_black"
                android:gravity="center"
                android:padding="10dp"
                android:text="@string/enter_title_challenge" />

            <!--Caja de textInput parael título-->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/outlined_text_input_title"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:hint="@string/title"
                android:paddingBottom="25dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:paddingStart="16dp" />
            </com.google.android.material.textfield.TextInputLayout>


            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:divider="@drawable/spacer_50dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingTop="25dp"
                android:paddingBottom="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/search_container">

                <!--Botón de cancelar -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/cancel_button"
                    style="@style/PixelBloomCancelButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="20dp"
                    android:layout_weight="1"
                    android:soundEffectsEnabled="true" />

                <!--Botón de confirmar -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/ok_button"
                    style="@style/PixelBloomConfirmButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_weight="1"
                    android:soundEffectsEnabled="true" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>