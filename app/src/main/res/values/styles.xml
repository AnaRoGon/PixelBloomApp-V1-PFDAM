<resources>


    <!-- ===========================
         Estilo para inputs Pixel Bloom
         =========================== -->
    <style name="PixelBloomTextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <!-- Bordes redondeados -->
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>

        <!-- Colores de borde -->
        <item name="boxStrokeColor">@color/purple</item>
        <item name="boxStrokeWidth">2dp</item>
        <item name="boxStrokeWidthFocused">3dp</item>

        <!-- Fondo -->
        <item name="boxBackgroundColor">@color/neutral_50</item>

        <!-- Icono inicial -->
        <item name="startIconTint">@color/neutral_700</item>

        <!-- LABEL (la etiqueta flotante) -->
        <item name="hintTextColor">@color/neutral_700</item>
    </style>


    <!-- ===========================
         Botón principal Pixel Bloom
         =========================== -->
    <style name="PixelBloomButton" parent="Widget.Material3.Button">
        <item name="cornerRadius">25dp</item>
        <item name="android:fontFamily">@font/inconsolata_black</item>
        <item name="backgroundTint">@color/btn_purple_pixel_bloom_color</item>
        <item name="strokeColor">@color/stroke_button_color</item>
        <item name="strokeWidth">2dp</item>
        <item name="android:textColor">@color/neutral_50</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- ===========================
     Botón split Pixel Bloom
     =========================== -->
    <style name="PixelBloom.SplitButton.Leading" parent="Widget.Material3.Button">
        <item name="android:fontFamily">@font/inconsolata_black</item>
        <item name="backgroundTint">@color/btn_purple_pixel_bloom_color</item>
        <item name="strokeColor">@color/stroke_button_color</item>
        <item name="strokeWidth">2dp</item>
        <item name="android:textColor">@color/neutral_50</item>
    </style>

    <style name="PixelBloom.SplitButton.Trailing" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/btn_purple_pixel_bloom_color</item>
        <item name="strokeColor">@color/stroke_button_color</item>
        <item name="strokeWidth">2dp</item>
    </style>

    <!-- ===========================
         Text Button Pixel Bloom
         =========================== -->
    <style name="PixelBloomTextButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@drawable/text_button_selector</item>
        <item name="android:fontFamily">@font/inconsolata_black</item>
        <item name="strokeWidth">0dp</item>
        <item name="android:strokeColor">@color/transparent</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- ===========================
     Text Button con icono Pixel Bloom
     =========================== -->
    <style name="PixelBloomIconTextButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:fontFamily">@font/inconsolata_black</item>
        <item name="android:textColor">@drawable/icon_text_button_selector</item>
        <item name="iconTint">@drawable/icon_text_button_selector</item>
        <item name="strokeWidth">0dp</item>
        <item name="android:strokeColor">@color/transparent</item>
        <item name="android:textAllCaps">false</item>

        <item name="iconPadding">8dp</item>
        <item name="android:paddingStart">12dp</item>
    </style>

    <!-- ===========================
         Bottom Navigation Pixel Bloom
         =========================== -->
    <style name="PixelBloomBottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@drawable/background_bottom_nav</item>
        <item name="android:backgroundTint">@null</item>

        <item name="colorSurface">@null</item>
        <item name="colorOnSurface">@null</item>

        <item name="android:elevation">0dp</item>
        <item name="itemIconSize">35dp</item>
        <item name="itemIconTint">@color/nav_item_color</item>
        <item name="labelVisibilityMode">unlabeled</item>
    </style>

    <!-- ===========================
         Toolbar Pixel Bloom
         =========================== -->
    <style name="PixelBloom.Widget.ToolbarTitle" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="fontFamily">@font/stick_no_bills</item>
        <item name="android:fontFamily">@font/stick_no_bills</item>
        <item name="android:textColor">@color/purple</item>
        <item name="android:textSize">35sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:backgroundTint">@color/neutral_50</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <!-- ===========================
         Border radius sólo en la izquierda para el cardview de settings
         =========================== -->
    <style name="ShapeAppearance.PixelBloom.LeftRounded" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeBottomLeft">24dp</item>
        <item name="cornerSizeTopRight">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <!-- ===========================
         Switch button Pixel Bloom
         =========================== -->
    <style name="PixelBloomSwitch" parent="Widget.Material3.CompoundButton.MaterialSwitch">
        <item name="thumbTint">@color/neutral_50</item>
        <item name="trackTint">@color/neutral_500</item>
        <item name="thumbIcon">@drawable/switch_thumb_shape</item>
        <item name="thumbIconSize">26dp</item>
        <item name="thumbIconTint">@color/neutral_50</item>

        <item name="trackDecorationTint">@android:color/transparent</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
        <item name="android:minHeight">0dp</item>
    </style>


    <!-- ===========================
         Floating button Pixel Bloom
         =========================== -->
    <style name="PixelBloomFloatingButton" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="android:backgroundTint">@color/purple</item>
        <item name="tint">@color/neutral_50</item>
        <item name="srcCompat">@drawable/ic_add</item>
        <item name="fabSize">normal</item>
        <item name="elevation">6dp</item>
        <item name="hoveredFocusedTranslationZ">12dp</item>
    </style>

    <!-- ===========================
     Alert Dialog Pixel Bloom
     =========================== -->
    <style name="PixelBloomAlertDialogTheme" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="materialButtonStyle">@style/Widget.Material3.Button.TextButton</item>
        <item name="android:fontFamily">@font/inconsolata_black</item>
        <item name="colorPrimary">@color/orange</item>
    </style>

    <!-- ===========================
     Popup Menu Pixel Bloom
     =========================== -->
    <style name="ThemeOverlay.PixelBloomPopupMenu" parent="Theme.AppCompat.Light">
        <item name="android:colorBackground">@color/neutral_200</item>
        <item name="android:textColor">@color/neutral_700</item>
        <item name="android:fontFamily">@font/inconsolata_black</item>
    </style>

    <!-- ===========================
         User Message 1 Pixel Bloom
         =========================== -->
    <style name="PixelBloomBoardMessage1">
        <item name="android:layout_margin">40dp</item>
        <item name="android:fontFamily">@font/inconsolata_black</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/light_purple</item>
        <item name="android:textSize">25sp</item>
    </style>

    <!-- ===========================
         User Message 2 Pixel Bloom
         =========================== -->
    <style name="PixelBloomBoardMessage2">
        <item name="android:layout_margin">40dp</item>
        <item name="android:paddingTop">20dp</item>
        <item name="android:fontFamily">@font/inconsolata_black</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">20sp</item>
    </style>

    <!-- ===========================
     User Message 3 Pixel Bloom
     =========================== -->
    <style name="PixelBloomBoardMessage3">
        <item name="android:layout_margin">60dp</item>
        <item name="android:background">@drawable/bg_rounded</item>
        <item name="android:fontFamily">@font/inconsolata_black</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">13dp</item>
        <item name="android:textColor">@color/neutral_50</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- ===========================
         Carousel Title Pixel Bloom
         =========================== -->
    <style name="PixelBloomCarouselTitle">
        <item name="android:layout_marginBottom">20dp</item>
        <item name="android:background">@color/neutral_50</item>
        <item name="android:fontFamily">@font/inconsolata_black</item>
        <item name="android:paddingStart">25dp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="android:textSize">25sp</item>
    </style>

    <!-- ===========================
         Details Title Pixel Bloom
         =========================== -->
    <style name="PixelBloomTitle">
        <item name="android:fontFamily">@font/inconsolata_black</item>
        <item name="android:gravity">start</item>
        <item name="android:textSize">25sp</item>
        <item name="android:paddingTop">20dp</item>
    </style>

    <!-- ===========================
         Subtitle Author Pixel Bloom
         =========================== -->
    <style name="PixelBloomSubtitle">
        <item name="android:fontFamily">@font/inconsolata_black</item>
        <item name="android:textColor">@color/purple</item>
        <item name="android:gravity">start</item>
        <item name="android:paddingTop">20dp</item>
    </style>


    <!-- ===========================
         Cancel Button Pixel Bloom
         =========================== -->
    <style name="PixelBloomCancelButton" parent="PixelBloomButton">
        <item name="backgroundTint">@color/btn_cancel_color</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="icon">@drawable/ic_decline</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">0dp</item>
        <item name="iconSize">19dp</item>
    </style>

    <!-- ===========================
         Confirm Button Pixel Bloom
         =========================== -->
    <style name="PixelBloomConfirmButton" parent="PixelBloomButton">
        <item name="backgroundTint">@color/purple</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="icon">@drawable/ic_confirm</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">0dp</item>
        <item name="iconSize">22dp</item>
    </style>

    <!-- ===========================
         Onboarding Title Pixel Bloom
         =========================== -->
    <style name="PixelBloomOnboardingTitle">
        <item name="android:fontFamily">@font/inconsolata_black</item>
        <item name="android:textColor">@color/orange</item>
        <item name="android:textSize">35sp</item>
    </style>

    <!-- ===========================
         Onboarding Nombre de la app Pixel Bloom
         =========================== -->
    <style name="PixelBloomOnboardingAppName">
        <item name="android:fontFamily">@font/stick_no_bills</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="android:textColor">@color/purple</item>
        <item name="android:textSize">50sp</item>
    </style>

    <!-- ===========================
         Onboarding Description Pixel Bloom
         =========================== -->
    <style name="PixelBloomOnboardingDescription">
        <item name="android:paddingTop">15dp</item>
        <item name="android:paddingBottom">15dp</item>
        <item name="android:fontFamily">@font/inconsolata_black</item>
        <item name="android:textColor">@color/neutral_700</item>
        <item name="android:textSize">20sp</item>
    </style>

</resources>
